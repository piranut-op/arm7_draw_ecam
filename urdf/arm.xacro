  <!-- Marker / pen tip: the physical marker sticks out 15 cm along the EE's
       local +Z (the tool axis). FK/IK use tip_link:=pen_tip so the marker TIP
       traces the path, not the EE flange. -->
  <xacro:property name="pen_length" value="0.15" />
  <joint name="pen_fix" type="fixed">
    <origin xyz="0 0 ${pen_length}" rpy="0 0 0" />
    <parent link="ee" />
    <child link="pen_tip" />
    <axis xyz="0 0 0" />
  </joint>
  <link name="pen_tip">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0" />
      <mass value="0.001" />
      <inertia ixx="1e-7" ixy="0" ixz="0" iyy="1e-7" iyz="0" izz="1e-7" />
    </inertial>
    <visual>
      <!-- shaft: cylinder along EE local Z, centred between flange and tip -->
      <origin xyz="0 0 ${-pen_length/2}" rpy="0 0 0" />
      <geometry>
        <cylinder radius="0.004" length="${pen_length}" />
      </geometry>
      <material name="pen_shaft">
        <color rgba="1.0 0.9 0.0 1" />
      </material>
    </visual>
    <visual>
      <!-- tip marker -->
      <origin xyz="0 0 0" rpy="0 0 0" />
      <geometry>
        <sphere radius="0.006" />
      </geometry>
      <material name="pen_point">
        <color rgba="1.0 0.9 0.0 1" />
      </material>
    </visual>
  </link>
